{
  "scheduler": {
    "concurrent_tasks": 1,
    "heartbeat_interval_seconds": 5.0
  },
  "worker": {
    "backend": "acp",
    "timeout_seconds": 300
  },
  "agents": {
    "default_agent_id": "engineer"
  },
  "approvals": {
    "preapprove_research_tasks": false
  },
  "integrations": {
    "enabled_providers": [],
    "trello": {
      "auto_sync_enabled": false,
      "pull_interval_seconds": 300,
      "board_id": null
    }
  }
}
