{
  "scheduler": {
    "concurrent_tasks": 1,
    "heartbeat_interval_seconds": 5.0
  },
  "worker": {
    "backend": "acp",
    "timeout_seconds": 300
  },
  "agents": {
    "default_agent_id": "engineer"
  },
  "approvals": {
    "preapprove_research_tasks": false
  },
  "integrations": {
    "enabled_providers": ["vikunja"],
    "providers": {
      "vikunja": {
        "project_id": "1",
        "view_id": "4",
        "bucket_map": {
          "to-do": "1",
          "doing": "2",
          "done": "3"
        }
      }
    }
  }
}
