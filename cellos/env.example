# Trello REST API credentials — CelloS uses API key + user token auth.
# Get them from https://trello.com/power-ups/admin
# Steps:
#   1) Create Power-Up
#   2) Generate API Key (API Key tab)
#   3) Generate a user token with write access, for example:
#      https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_API_KEY
#   4) Allow access and copy the token shown
TRELLO_API_KEY=your_api_key_here
TRELLO_TOKEN=your_token_here

# Optional: name for auto-created Trello board (default: "CelloS")
CELLOS_TRELLO_PROJECT_NAME=CelloS
